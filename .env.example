# ── Database ──────────────────────────────────────────────────────────────────
# 本地 Postgres 示例：postgresql://postgres:password@127.0.0.1:5432/atoms?schema=public
# Docker 内连宿主机示例：postgresql://postgres:password@host.docker.internal:5432/atoms?schema=public
DATABASE_URL="postgresql://postgres:your_password@127.0.0.1:5432/atoms?schema=public"

# ── AI Provider（默认模型选择）─────────────────────────────────────────────────
# 可选值：anthropic | openai | bailian
AI_PROVIDER="bailian"
# 对应 src/lib/models.ts 中的 model 字段，需与 AI_PROVIDER 匹配
# anthropic 可用：claude-sonnet-4-6 | claude-opus-4-6 | claude-haiku-4-5-20251001
# openai 可用：gpt-5.4 | gpt-5.4-mini | gpt-5.3-codex | gpt-5.2-codex | gpt-5.2 | gpt-5.1-codex-max | gpt-5.1-codex-mini
# bailian 可用：qwen3.5-plus | qwen3-max-2026-01-23 | qwen3-coder-next | qwen3-coder-plus | glm-5 | glm-4.7 | kimi-k2.5 | MiniMax-M2.5
AI_MODEL="qwen3.5-plus"

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-xxxxxxxx"
# 自定义端点（可选，默认 https://api.anthropic.com）
# ANTHROPIC_BASE_URL="https://your-anthropic-proxy.com"

# ── OpenAI / 兼容 API ─────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-xxxxxxxx"
# 自定义端点（可选，默认 https://api.openai.com/v1）
OPENAI_BASE_URL="https://api.openai.com/v1"

# ── 阿里云百炼 / DashScope（OpenAI 兼容模式）─────────────────────────────────
DASHSCOPE_API_KEY="sk-xxxxxxxx"
# 默认官方端点，可替换为自定义代理
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# ── Session ──────────────────────────────────────────────────────────────────
# 至少 32 位随机字符串，用于加密 session cookie
# 生成命令：openssl rand -base64 32
SESSION_SECRET="replace-with-a-random-32-char-secret-here"

# ── App URL ───────────────────────────────────────────────────────────────────
# 无尾斜杠；HTTPS 域名时 cookie 会自动设为 secure
# 本地开发：http://localhost:3000
# 生产部署：https://your-domain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"
