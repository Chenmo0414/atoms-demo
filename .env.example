# PostgreSQL
# 例子：postgresql://postgres:your_password@127.0.0.1:5432/atoms_demo?schema=public
DATABASE_URL="postgresql://postgres:your_password@127.0.0.1:5432/atoms_demo?schema=public"

# 阿里云百炼 / DashScope（OpenAI 兼容模式）
DASHSCOPE_API_KEY="sk-xxxxxxxx"
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
BAILIAN_MODEL="qwen-plus"

# Session secret（至少 32 位）
SESSION_SECRET="replace-with-a-random-32-char-secret"

# App URL（无尾斜杠）
NEXT_PUBLIC_APP_URL="http://localhost:3000"
